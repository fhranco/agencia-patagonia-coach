<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]

  # 1. If it's a real file or directory, stop and serve it
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # 2. SEO Cleanup: Signal Google that old URLs are permanently Gone (410)
  RewriteRule ^servicio/.*$ - [G,L]
  RewriteRule ^tienda/.*$ - [G,L]
  RewriteRule ^home/.*$ - [G,L]

  # 3. SPA Fallback: Everything else to index.html
  RewriteRule . /index.html [L]
</IfModule>

# Security Headers
<IfModule mod_headers.c>
  Header set X-XSS-Protection "1; mode=block"
  Header set X-Frame-Options "DENY"
  Header set X-Content-Type-Options "nosniff"
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# Caching for Performance
<FilesMatch "\.(ico|pdf|flv|jpg|jpeg|png|gif|js|css|swf|webp|svg|xml)$">
  Header set Cache-Control "max-age=31536000, public"
</FilesMatch>
